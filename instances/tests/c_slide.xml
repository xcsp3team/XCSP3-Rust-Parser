<instance format="XCSP3" type="CSP">
    <variables>
        <array id="y" size="[8]">0 1</array>
        <array id="z" size="[6]">0 1</array>
        <array id="t" size="[6]">0 1</array>
        <var id="b">1..5</var>
        <var id="c">1..5</var>
        <var id="d">1..5</var>
    </variables>
    <constraints>
        <slide id="c1">
            <list>y[]</list>
            <intension>eq(add(%0,%1),%2)</intension>
        </slide>
        <slide id="c2" circular="true">
            <list>z[]</list>
            <extension>
                <list>%0 %1</list>
                <supports>(1,2)(1,3)(2,0) (2,1)</supports>
            </extension>
        </slide>
        <slide id="c3">
            <list offset="2">y[0] t[0] y[1] t[1] y[2] t[2]</list>
            <intension>ne(%0,%1)</intension>
        </slide>
    </constraints>
</instance>

